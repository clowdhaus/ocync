---
import BaseLayout from "../layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
---

<BaseLayout title="Page not found" description="The page you are looking for does not exist." noindex>
  <main id="main-content" class="not-found">
    <h1>Page not found</h1>
    <p>The page you are looking for does not exist or has been moved.</p>
    <a href={base} class="back-link">Back to home</a>
  </main>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-block-size: calc(100dvh - 12rem);
    padding: var(--space-8);

    & h1 {
      font-size: var(--text-4xl);
      color: var(--pink);
    }

    & p {
      margin-block-start: var(--space-4);
      color: var(--color-text-muted);
      font-size: var(--text-lg);
    }
  }

  .back-link {
    display: inline-flex;
    margin-block-start: var(--space-8);
    padding-block: var(--space-3);
    padding-inline: var(--space-8);
    border-radius: var(--radius-pill);
    background-color: var(--violet);
    color: var(--color-text-inverse);
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.15s;

    &:hover {
      transform: translateY(-1px);
      background-color: var(--purple);
      color: var(--color-text-inverse);
    }
  }
</style>
